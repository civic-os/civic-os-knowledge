apiVersion: v1
kind: Secret
metadata:
  name: civic-os-kb-secrets
type: Opaque
stringData:
  KB_S3_ENDPOINT: "https://nyc3.digitaloceanspaces.com"
  KB_S3_REGION: "nyc3"
  KB_S3_BUCKET: "civic-os-kb"
  KB_S3_PREFIX: "knowledge/"
  KB_S3_ACCESS_KEY: ""
  KB_S3_SECRET_KEY: ""
  KB_KEYCLOAK_URL: "https://auth.civic-os.org"
  KB_KEYCLOAK_REALM: "central-os"
  KB_KEYCLOAK_CLIENT_ID: "civic-os-kb"
  KB_KEYCLOAK_CLIENT_SECRET: ""
  KB_EXTERNAL_URL: "https://kb.civic-os.org"
  KB_SESSION_KEY: ""
  KB_VIZ_ROLES: "kb-viewer,kb-admin"
